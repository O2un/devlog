---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import companyOneImage from '../assets/bg/bd.jpg';
import companyTwoImage from '../assets/bg/cn.jpg';
import journeyImage from '../assets/bg/bmo.gif';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			:global(body) {
				background: #0b1326;
				color: #dae2fd;
			}
			:global(html),
			:global(body) {
				overflow-x: hidden;
			}
			main {
				width: 100%;
				max-width: 100%;
				padding: 0;
				overflow-x: clip;
			}
			.section-inner {
				width: min(1200px, calc(100% - 2rem));
				max-width: calc(100% - 2rem);
				margin: 0 auto;
			}
			.intro {
				padding: 5rem 0 4.5rem;
			}
			.intro-kicker {
				margin: 0 0 0.75rem;
				font-size: 0.95rem;
				color: #bbcabf;
				letter-spacing: 0;
			}
			.intro h1 {
				margin-bottom: 1rem;
				font-size: clamp(2rem, 4vw, 3.4rem);
			}
			.intro p {
				max-width: 680px;
				margin: 0.85rem auto 0;
				text-align: left;
				color: #dae2fd;
			}
			.intro h3 {
				max-width: 680px;
				margin: 0 auto 1.6rem;
				text-align: center;
				font-size: 2.1rem;
				white-space: nowrap;
				color: #4edea3;
			}
			.career {
				padding-top: 2.25rem;
				padding-bottom: 5rem;
			}
			.journey-break {
				position: relative;
				display: grid;
				grid-template-columns: minmax(260px, 0.85fr) minmax(0, 1fr);
				align-items: center;
				gap: 3rem;
				min-height: 220px;
				padding: 0 max(1rem, calc((100vw - 1200px) / 2));
				overflow: hidden;
				isolation: isolate;
				width: 100%;
				background: #060e20;
				border-top: 1px solid #3c4a42;
				border-bottom: 1px solid #3c4a42;
			}
			.journey-media {
				justify-self: start;
				align-self: stretch;
				overflow: hidden;
				width: min(460px, 100%);
				height: 100%;
				margin: 0;
				border: 1px solid rgba(78, 222, 163, 0.22);
				border-radius: 4px;
				background: #131b2e;
			}
			.journey-media img {
				display: block;
				width: 100%;
				height: 100%;
				object-fit: cover;
				border-radius: 0;
			}
			.journey-break p {
				position: relative;
				justify-self: center;
				margin: 0;
				font-size: clamp(1.05rem, 2vw, 1.4rem);
				font-weight: 600;
				text-align: center;
				color: #dae2fd;
			}
			.career-title {
				margin: 0 0 1.25rem;
				font-size: clamp(1.4rem, 2.5vw, 2rem);
			}
			.experience-band {
				position: relative;
				min-height: 78vh;
				padding: 4.5rem 0;
				overflow: hidden;
				isolation: isolate;
			}
			.experience-band + .experience-band {
				margin-top: 1rem;
			}
			.experience-band.left {
				background: linear-gradient(90deg, rgba(16, 185, 129, 0.12) 0%, rgba(11, 19, 38, 0.92) 50%, #0b1326 100%);
			}
			.experience-band.right {
				background: linear-gradient(270deg, rgba(16, 185, 129, 0.12) 0%, rgba(11, 19, 38, 0.92) 50%, #0b1326 100%);
			}
			.experience-media {
				position: absolute;
				inset: 0;
				opacity: 0;
				transition: transform 600ms ease, opacity 600ms ease;
				z-index: 0;
			}
			.experience-media img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				border-radius: 0;
			}
			.experience-band.left .experience-media {
				transform: translateX(-8%);
			}
			.experience-band.right .experience-media {
				transform: translateX(8%);
			}
			.experience-band.left.in-view .experience-media {
				transform: translateX(0);
			}
			.experience-band.right.in-view .experience-media {
				transform: translateX(0);
			}
			.experience-band.in-view .experience-media {
				opacity: 1;
			}
			.experience-band::before {
				content: '';
				position: absolute;
				inset: 0;
				z-index: 1;
				background: linear-gradient(180deg, rgba(6, 14, 32, 0.12) 0%, rgba(6, 14, 32, 0.3) 60%, rgba(6, 14, 32, 0.55) 100%);
			}
			.experience-band.left::after,
			.experience-band.right::after {
				content: '';
				position: absolute;
				inset: 0;
				z-index: 1;
				pointer-events: none;
			}
			.experience-band.left::after {
				background: linear-gradient(90deg, rgba(16, 185, 129, 0.2) 0%, rgba(16, 185, 129, 0.08) 34%, rgba(6, 14, 32, 0) 65%);
			}
			.experience-band.right::after {
				background: linear-gradient(270deg, rgba(16, 185, 129, 0.2) 0%, rgba(16, 185, 129, 0.08) 34%, rgba(6, 14, 32, 0) 65%);
			}
			.experience-content-wrap {
				position: relative;
				z-index: 3;
				display: flex;
				min-height: 62vh;
				align-items: flex-end;
				padding-bottom: 1.2rem;
			}
			.experience-band.left .experience-content-wrap {
				justify-content: flex-end;
			}
			.experience-band.right .experience-content-wrap {
				justify-content: flex-start;
			}
			.experience-content {
				width: min(500px, 100%);
				border: 1px solid #3c4a42;
				border-radius: 4px;
				padding: 1.5rem;
				background: rgba(19, 27, 46, 0.74);
				backdrop-filter: blur(2px);
				color: #dae2fd;
				opacity: 0;
				transition: transform 500ms ease, opacity 500ms ease;
			}
			.experience-band.left .experience-content {
				transform: translateX(48px);
			}
			.experience-band.right .experience-content {
				transform: translateX(-48px);
			}
			.experience-band.in-view .experience-content {
				opacity: 1;
				transform: translateX(0);
			}
			.experience-content h3 {
				font-size: 1.3rem;
				margin-bottom: 0.45rem;
			}
			.experience-content .period {
				margin: 0 0 1rem;
				font-size: 0.92rem;
				color: #bbcabf;
			}
			.experience-content p {
				margin: 0.4rem 0;
				font-size: 1rem;
				line-height: 1.5;
			}
			.experience-content h3,
			.experience-content strong {
				color: #4edea3;
			}
			.experience-content a {
				color: #4cd7f6;
			}
			.experience-content a:hover {
				color: #acedff;
			}
			@media (max-width: 920px) {
				.section-inner {
					width: 100%;
					max-width: 100%;
					padding: 0 1rem;
					box-sizing: border-box;
				}
				.journey-break,
				.experience-band {
					width: 100vw;
					margin-left: calc(50% - 50vw);
					margin-right: calc(50% - 50vw);
				}
				.intro h3 {
					white-space: normal;
				}
				.journey-break {
					grid-template-columns: minmax(140px, 44vw) minmax(0, 1fr);
					gap: 0.75rem;
					min-height: 180px;
					padding: 0 1rem 0 0;
				}
				.journey-media {
					width: 100%;
					height: 100%;
					border-left: 0;
				}
				.experience-band {
					padding: 2.5rem 0;
					min-height: 72vh;
				}
				.experience-media {
					transform: none !important;
					opacity: 1;
				}
				.experience-band::before {
					background: linear-gradient(180deg, rgba(0, 0, 0, 0.1) 0%, rgba(0, 0, 0, 0.28) 70%, rgba(0, 0, 0, 0.46) 100%);
				}
				.experience-content-wrap {
					min-height: auto;
					justify-content: stretch !important;
				}
				.experience-content {
					width: 100%;
					transform: translateY(24px) !important;
				}
				.experience-band.in-view .experience-content {
					transform: translateY(0) !important;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="intro section-inner">
				<p class="intro-kicker">Developer Introduction</p>
				<h3>게임을 좋아하고, 끝까지 완성해내는 개발자 입니다</h3>
				<p>
					아주 어렸을적 부터 게임 개발자가 꿈이 었습니다, 펄어비스를 시작으로 약 10년간 다양한 게임 프로젝트를 만들며 경험을 쌓았습니다.
					특정 기술 하나에만 머물기보다, 프로젝트에 맞는 방법을 빠르게 익혀 실제 결과로 연결하는 것을 중요하게 생각합니다.
				</p>
				<p>
					저는 단순히 기능을 만드는 데서 멈추지 않고, 기획 의도를 이해하고 팀과 함께 더 좋은 방향을 찾는 과정을
					좋아합니다. 앞으로도 사용자에게 오래 기억되는 게임 경험을 만드는 개발자가 되고자 합니다.
				</p>
			</section>

			<section class="journey-break" id="journey-break">
				<figure class="journey-media">
					<Image src={journeyImage} alt="경력 소개 배경 이미지" />
				</figure>
				<p>제가 걸어온 길을 소개합니다</p>
			</section>

			<section class="career">
				<div class="section-inner">
					
				</div>

				<article class="experience-band left" data-band>
					<figure class="experience-media">
						<Image src={companyOneImage} alt="펄어비스 검은사막 온라인 스크린샷" />
					</figure>
					<div class="section-inner experience-content-wrap">
						<div class="experience-content">
							<h3>펄어비스</h3>
							<p class="period">2016 - 2022</p>
							<p><strong>검은사막 온라인</strong>의 전투/PVP 콘텐츠 개발에 참여했습니다.</p>
							<p>
								<a href="https://www.playblackdesert.com/" target="_blank" rel="noopener noreferrer">게임 페이지 보기</a>
							</p>
						</div>
					</div>
				</article>

				<article class="experience-band right" data-band>
					<figure class="experience-media">
						<Image src={companyTwoImage} alt="데브시스터즈 쿠키런 더 다키스트 나이트 스크린샷" />
					</figure>
					<div class="section-inner experience-content-wrap">
						<div class="experience-content">
							<h3>데브시스터즈</h3>
							<p class="period">2022 - 2024</p>
							<p><strong>쿠키런: 더 다키스트 나이트</strong> VR 액션 어드벤처 개발에 참여했습니다.</p>
							<p>
								<a href="https://www.meta.com/ko-kr/experiences/cookierun-the-darkest-night-chapter1/5240965299324322/" target="_blank" rel="noopener noreferrer">게임 페이지 보기</a>
							</p>
						</div>
					</div>
				</article>
			</section>
		</main>
		<Footer />
		<script>
			const bands = Array.from(document.querySelectorAll('[data-band]'));
			if (bands.length > 0) {
				const observer = new IntersectionObserver(
					(entries) => {
						for (const entry of entries) {
							entry.target.classList.toggle('in-view', entry.isIntersecting);
						}
					},
					{ threshold: 0.2, rootMargin: '0px 0px -10% 0px' }
				);
				for (const band of bands) observer.observe(band);
			}
		</script>
	</body>
</html>
